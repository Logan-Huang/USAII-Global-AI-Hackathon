# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your NEW (rotated) Anthropic API key.
# NEVER commit .env. The key is used server-side ONLY and is never sent to the
# browser. Set a spend limit on the key in the Anthropic Console as well.
# ─────────────────────────────────────────────────────────────────────────────

# Your rotated Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-new-rotated-key-here

# Server bind address. 127.0.0.1 = localhost only (maximum security, default).
# For public hosting later, see SECURITY.md before changing HOST to 0.0.0.0.
HOST=127.0.0.1
PORT=3000

# Claude model. Tip: develop/test on a cheaper model to save cost, demo on Opus.
#   claude-opus-4-8   (best quality — default)
#   claude-sonnet-4-6 (about half the cost)
#   claude-haiku-4-5  (cheapest, fastest)
CLAUDE_MODEL=claude-opus-4-8

# CORS allowed origins (comma-separated). Leave blank for same-origin localhost.
# When hosting publicly, set this to your deployed frontend origin.
ALLOWED_ORIGIN=

# Per-IP rate limiting on /api/*
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=20
